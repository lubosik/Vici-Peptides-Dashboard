# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# WooCommerce (use your store URL — e.g. https://vicipeptides.com)
WOOCOMMERCE_STORE_URL=https://vicipeptides.com
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

# Shippo
SHIPPO_API_TOKEN=

# Make.com webhook (order ingestion: POST /api/webhooks/order)
# Generate a secure random string (e.g. vici_webhook_xxx) and set the same in Make.com HTTP module
WEBHOOK_API_KEY=

# Basic auth (optional)
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# ShipStation (API key and secret from Account Settings → API Keys)
SHIPSTATION_API_KEY=
SHIPSTATION_API_SECRET=

# WooCommerce Webhook Secret (generate a random string, enter same value in WordPress webhook settings)
WOOCOMMERCE_WEBHOOK_SECRET=
